    <dashboard name='Story on Electricity Consumption in India' type='storyboard'>
      <style />
      <size maxheight='964' maxwidth='1016' minheight='964' minwidth='1016' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='98340' id='1' param='vert' removable='false' type-v2='layout-flow' w='98426' x='787' y='830'>
            <zone h='5187' id='3' type-v2='title' w='98426' x='787' y='830' />
            <zone h='10477' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='98426' x='787' y='6017' />
            <zone h='82676' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='98426' x='787' y='16494'>
              <flipboard active-id='7' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='Electricity Consumption by Indian states in 2019' captured-sheet='2019 State Consumption' id='1'>
                    <capturedDeltas>
                      <worksheet name='2019 State Consumption'>
                        <style delta-type='added'>
                          <style-rule element='axis'>
                            <encoding attr='space' class='0' field='[federated.0nzlmpl1kv5g8j0zk3tzo1f6s7qc].[avg:latitude:qk]' field-type='quantitative' max='5266895.036863042' min='-392154.4849870482' projection='EPSG:3857' range-type='fixed' scope='rows' type='space' />
                            <encoding attr='space' class='0' field='[federated.0nzlmpl1kv5g8j0zk3tzo1f6s7qc].[avg:longitude:qk]' field-type='quantitative' max='12469078.531199308' min='6175297.9490219997' projection='EPSG:3857' range-type='fixed' scope='cols' type='space' />
                          </style-rule>
                        </style>
                      </worksheet>
                    </capturedDeltas>
                  </story-point>
                  <story-point caption='Electricity Consumption by Indian states in 2020' captured-sheet='2020 State Consumption' id='2'>
                    <capturedDeltas>
                      <worksheet name='2020 State Consumption'>
                        <style delta-type='added'>
                          <style-rule element='axis'>
                            <encoding attr='space' class='0' field='[federated.0nzlmpl1kv5g8j0zk3tzo1f6s7qc].[Latitude (generated)]' field-type='quantitative' max='4476305.7353042914' min='22436.556054182234' projection='EPSG:3857' range-type='fixed' scope='rows' type='space' />
                            <encoding attr='space' class='0' field='[federated.0nzlmpl1kv5g8j0zk3tzo1f6s7qc].[Longitude (generated)]' field-type='quantitative' max='11318353.469516676' min='6364928.8267936278' projection='EPSG:3857' range-type='fixed' scope='cols' type='space' />
                          </style-rule>
                        </style>
                      </worksheet>
                    </capturedDeltas>
                  </story-point>
                  <story-point caption='Bar plot for Total Electricity Consumption by Indian States in Year 2019 and 2020' captured-sheet='Total Consumption' id='3' />
                  <story-point caption='Region wise plot clearly  states consumption in 2019 is more as compared to 2020' captured-sheet='Year wise Consumption in Region' id='4' />
                  <story-point caption='plot defines top consumption by Indian states in year 2019 and 2020' captured-sheet='Top N' id='5' />
                  <story-point caption='plot defines Bottom Consumption by Indian states in the year 2019 and 2020' captured-sheet='Bottom N' id='6' />
                  <story-point caption='In Year 2019,Electricity Consumption by India was highest in July followed by August and December' captured-sheet='2019 Monthwise Consumption' id='7' />
                  <story-point caption='In Year 2020,Electricity Consumption by India was highest in January' captured-sheet='2020 Monthwise Consumption' id='8' />
                  <story-point caption='Electricity Consumption for period of March to June was less in 2020as compared to 2019 because of lockdown' captured-sheet='Usage before and during lockdown' id='9' />
                  <story-point caption='The Most Electricity Consumption is highest in Western Region whereas NER has less Consumption' captured-sheet='Region Wise Consumption' id='10' />
                  <story-point caption='Maharashtra has highest usage of Electricity and its peak on Q3 of 2019 and itd lowest Consumption is in Q4 of 2020' captured-sheet='Metro Usage City' id='11'>
                    <capturedDeltas>
                      <worksheet name='Metro Usage City'>
                        <style delta-type='added'>
                          <style-rule element='axis'>
                            <encoding attr='space' class='0' field='[federated.0nzlmpl1kv5g8j0zk3tzo1f6s7qc].[sum:Usage:qk]' field-type='quantitative' max='16797.575512400614' min='-1239.7490362298718' range-type='fixed' scope='rows' type='space' />
                            <encoding attr='space' class='0' field='[federated.0nzlmpl1kv5g8j0zk3tzo1f6s7qc].[tmn:Dates:qk]' field-type='quantitative' max='#2021-01-21 04:16:54.868#' min='#2018-09-15 04:02:25.650#' range-type='fixed' scope='cols' type='space' />
                          </style-rule>
                        </style>
                      </worksheet>
                    </capturedDeltas>
                  </story-point>
                  <story-point caption='In Year 2019,Electricity Consumption was more as compared to 2020 in India' captured-sheet='Usage By Year' id='12' />
                </story-points>
              </flipboard>
            </zone>
          </zone>
